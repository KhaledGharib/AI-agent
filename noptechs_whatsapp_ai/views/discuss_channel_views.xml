<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="discuss_channel_view_form_whatsapp_ai" model="ir.ui.view">
        <field name="name">discuss.channel.form.whatsapp.ai</field>
        <field name="model">discuss.channel</field>
        <field name="inherit_id" ref="mail.discuss_channel_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <header>
                    <field name="wa_account_id" invisible="1"/>
                    <field name="whatsapp_ai_paused" invisible="1"/>
                    <button name="action_whatsapp_ai_pause" type="object" string="Pause AI Replies"
                            invisible="channel_type != 'whatsapp' or not wa_account_id or whatsapp_ai_paused"/>
                    <button name="action_whatsapp_ai_resume" type="object" string="Resume AI Replies"
                            class="btn-primary"
                            invisible="channel_type != 'whatsapp' or not wa_account_id or not whatsapp_ai_paused"/>
                </header>
            </xpath>
            <xpath expr="//page[@name='extra_info']/group" position="inside">
                <field name="whatsapp_ai_paused"
                       invisible="channel_type != 'whatsapp'"/>
            </xpath>
        </field>
    </record>
</odoo>
